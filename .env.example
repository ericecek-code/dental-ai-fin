# DenteScope AI — Production environment variables (.env)
# Tento subor NIKDY necommituj (.gitignore ho blokuje).

# --- Backend FastAPI ---
APP_NAME="DenteScope AI"
APP_VERSION="0.1.0"
PORT=8000

# --- Upload limity ---
UPLOAD_MAX_SIZE_MB=50

# --- CORS — povolene origins pre frontend ---
# Ak hostujes frontend inde ako localhost:5173, pridaj jeho domenu sem.
# Pre RunPod proxy povol aj *.runpod.io
CORS_ORIGINS='[
  "https://dentescope.ai",
  "https://app.dentescope.ai",
  "http://localhost:5173",
  "http://127.0.0.1:5173"
]'

# --- YOLOv8 weights ---
WEIGHTS_PATH=/app/weights/yolov8x_dental.pt
# Volitelne: stiahnutie pri starte (ak nastavis, WEIGHTS_PATH sa ignoruje)
# WEIGHTS_URL=https://moj-bucket.s3.amazonaws.com/yolov8x_dental.pt

# --- Bezpecnost ---
# API token pre externy pristup (Hermes, monitoring, ine automaty).
# Generuj s: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Povinne zmenit pred deploy!
API_TOKEN=replace-with-generated-token

# --- Logovanie ---
LOG_LEVEL=INFO
